# =========================================================================
# AGENT VOCAL PLOMBIER - VARIABLES D'ENVIRONNEMENT
# Copier ce fichier en ".env" puis remplacer chaque valeur [A COMPLETER].
# Ne jamais committer le fichier ".env" reel (contient des secrets).
# =========================================================================


# --- VAPI (plateforme de l'agent vocal) ---------------------------------

# Cle API privee Vapi (Dashboard Vapi > Settings > API Keys > Private Key).
# Utilisee pour creer/mettre a jour l'assistant et le numero de telephone via l'API Vapi.
VAPI_API_KEY=[A COMPLETER - sk_xxx... clé privée Vapi]

# Identifiant de l'assistant Vapi cree a partir de vapi-config.json
# (recupere apres creation de l'assistant via le dashboard ou l'API Vapi).
VAPI_ASSISTANT_ID=[A COMPLETER - ex: 1234abcd-...]

# Identifiant du numero de telephone Vapi attribue a cet assistant
# (Dashboard Vapi > Phone Numbers).
VAPI_PHONE_NUMBER_ID=[A COMPLETER - ex: 5678efgh-...]

# Secret partage verifie a chaque appel webhook recu par n8n (voir workflow-n8n.json,
# noeud "Verifier secret webhook"). DOIT etre identique a "serverUrlSecret" dans vapi-config.json.
VAPI_WEBHOOK_SECRET=[A COMPLETER - chaine aleatoire longue, ex generee avec `openssl rand -hex 32`]

# URL du webhook n8n appelee par Vapi a la fin de chaque appel (champ "serverUrl" de
# l'assistant Vapi, voir vapi-config.json). Doit pointer vers le noeud Webhook du
# workflow-n8n.json une fois celui-ci importe et active sur l'instance n8n.
VAPI_SERVER_URL=[A COMPLETER - ex: https://votre-instance.app.n8n.cloud/webhook/xxxxxxxx]


# --- LLM (Anthropic Claude) ----------------------------------------------

# Optionnel : uniquement necessaire si vous configurez votre PROPRE cle Anthropic
# dans Vapi ("Bring your own key") au lieu d'utiliser le credit Anthropic inclus
# par defaut dans Vapi. Sinon, laisser vide / ne pas definir.
ANTHROPIC_API_KEY=[A COMPLETER - optionnel - clé API Anthropic (sk-ant-...)]


# --- ENTREPRISE / ARTISAN -------------------------------------------------

# Nom de l'entreprise utilise dans les SMS envoyes par le workflow n8n.
COMPANY_NAME=[A COMPLETER - ex: Plomberie Dupont]

# Numero de telephone PERSONNEL de l'artisan/plombier, au format international.
# Utilise par n8n pour lui envoyer un SMS d'alerte en cas d'appel urgent.
ARTISAN_PHONE_NUMBER=[A COMPLETER - ex: +33612345678]


# --- SMS (Twilio) -------------------------------------------------------
# Utilise par server.js pour l'envoi du SMS recapitulatif a l'artisan apres
# chaque appel, via l'API REST Twilio (Messages.json).

# Console Twilio > Account Info > Account SID
TWILIO_ACCOUNT_SID=[A COMPLETER - ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx]

# Console Twilio > Account Info > Auth Token
TWILIO_AUTH_TOKEN=[A COMPLETER - clé secrète Twilio]

# Numero de telephone Twilio expediteur des SMS (achete dans la console Twilio),
# au format international avec le '+' (ex: +33756000000).
TWILIO_FROM_NUMBER=[A COMPLETER - ex: +33756000000]


# --- N8N (orchestration du workflow SMS) -----------------------------------

# URL publique de votre instance n8n (utile si vous generez l'URL du webhook
# dynamiquement plutot que de la copier-coller manuellement dans vapi-config.json).
N8N_BASE_URL=[A COMPLETER - ex: https://votre-instance-n8n.com]
